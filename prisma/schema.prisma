// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?   
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relacje better-auth (wymagane!)
  sessions      Session[]
  accounts      Account[]
  
  // custom relacje
  savedRepos    SavedRepository[]
  techNotes     TechNote[]
  preferences   UserPreferences?
  
  @@map("users") // Nazwa tabeli w bazie danych
}

/// Model sesji - przechowuje aktywne sesje zalogowanych userów
model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relacja do User
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("sessions")
}

/// Metody logowania (email/password, OAuth)
model Account {
  id                String    @id @default(cuid())
  userId            String
  accountId         String    // ID z providera (np. Google ID)
  providerId        String    // "credential", "google", "github"
  accessToken       String?   @db.Text // Token OAuth
  refreshToken      String?   @db.Text
  idToken           String?   @db.Text
  expiresAt         DateTime?
  password          String?   // Hash hasła (tylko dla credential)
  createdAt         DateTime  @default(now())
  updatedAt    DateTime  @updatedAt  
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

/// Model weryfikacji - tokeny do weryfikacji emaila
model Verification {
  id         String   @id @default(cuid())
  identifier String   // Email usera
  value      String   // Token weryfikacyjny
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([identifier, value])
  @@map("verifications")
}

/// Zapisane repozytoria GitHub
model SavedRepository {
  id          String   @id @default(cuid())
  userId      String
  
  // Dane z GitHub API
  githubId    Int      // ID repo na GitHubie
  name        String   // Nazwa repo
  fullName    String   // owner/repo
  description String?  @db.Text
  url         String
  stars       Int      @default(0)
  language    String?  // Główny język programowania
  topics      String[] // Tagi (array of strings)
  
  // Metadata
  savedAt     DateTime @default(now())
  notes       String?  @db.Text // Notatki usera
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, githubId]) // User nie może zapisać tego samego repo 2 razy
  @@index([userId])
  @@map("saved_repositories")
}

/// Notatki techniczne 
model TechNote {
  id        String   @id @default(cuid())
  userId    String
  
  title     String
  content   String   @db.Text
  category  String?  // "tutorial", "snippet", "idea", "bug-fix"
  tags      String[] // ["react", "typescript", "performance"]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([category])
  @@map("tech_notes")
}

/// Preferencje 
model UserPreferences {
  id              String  @id @default(cuid())
  userId          String  @unique
  
  // GitHub integration
  githubUsername  String?
  
  // Dashboard settings
  theme           String  @default("system") // "light", "dark", "system"
  defaultView     String  @default("overview") // Jaki widok po zalogowaniu
  
  // Notifications
  emailNews       Boolean @default(true)
  emailDigest     Boolean @default(false)
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("user_preferences")
}

/// Cache dla danych z zewnętrznych API
model ApiCache {
  id        String   @id @default(cuid())
  
  // Klucz cache (np.github:user:octocat
  cacheKey  String   @unique
  
  // Dane z API (JSON)
  data      Json
  
  // Wygaśnięcie
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  @@index([cacheKey])
  @@index([expiresAt])
  @@map("api_cache")
}
